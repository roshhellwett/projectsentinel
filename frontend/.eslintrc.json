{
  "extends": [
    "next/core-web-vitals"
  ],
  "rules": {
    "react-hooks/exhaustive-deps": "warn",
    "no-console": [
      "warn",
      {
        "allow": [
          "warn",
          "error"
        ]
      }
    ],
    "no-debugger": "error",
    "@next/next/no-img-element": "warn",
    "@next/next/no-html-link-for-pages": "warn"
  },
  "overrides": [
    {
      "files": [
        "components/news/NewsCard.tsx",
        "components/news/SourceLinks.tsx",
        "components/news/SourcePickerButton.tsx",
        "components/news/DrawerContent.tsx"
      ],
      "rules": {
        "@next/next/no-img-element": "off"
      }
    }
  ]
}