# Supabase
SUPABASE_URL="your_supabase_url"
SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# AI — Gemini
GEMINI_API_KEY="your_gemini_api_key"

# AI — Groq (Verification)
GROQ_API_KEY_VERIFY="your_groq_verify_api_key"
GROQ_VERIFY_MODEL="llama3-8b-8192"

# AI — Groq (Writing)
GROQ_API_KEY="your_groq_write_api_key"
GROQ_WRITE_MODEL="llama3-70b-8192"

# News APIs
GNEWS_API_KEY="your_gnews_api_key"
NEWSAPI_KEY="your_newsapi_key"

# Admin
ADMIN_PASSWORD="your_admin_password"
ADMIN_SECRET_TOKEN="your_admin_secret_token"

# App config (frontend)
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
NEXT_PUBLIC_SUPABASE_URL="your_supabase_url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"

# Worker CORS
CORS_ORIGINS="https://sentinelnews.vercel.app"

# Backend (Railway) specific
RAILWAY_URL="your_railway_url"

# Pipeline config
MAX_AI_GROUPS_PER_RUN="4"
