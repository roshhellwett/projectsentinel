# ─────────────────────────────────────────────────────────────────────
# India Verified — Frontend Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Get Supabase credentials from: https://supabase.com/dashboard/project/<id>/settings/api

# Supabase (required for data fetching)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (used for RSS, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin authentication (optional, for /admin panel)
# Generate with: openssl rand -hex 32
ADMIN_SECRET_TOKEN=your-admin-secret-token
ADMIN_PASSWORD=your-admin-password

# Google Tag Manager (optional)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Sentry error tracking (optional)
# Get from: https://sentry.io/settings/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=https://your-public-key@your-org.ingest.sentry.io/project-id
# SENTRY_DSN=https://your-server-key@your-org.ingest.sentry.io/project-id
