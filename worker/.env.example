# ─────────────────────────────────────────────────────────────────────
# India Verified — Worker Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.

# Supabase (required)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq API keys (at least one required)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here
GROQ_API_KEY_VERIFY=gsk_your-verify-key-here

# Optional: additional Groq keys for rotation and tiering
# GROQ_API_KEY_2=...
# GROQ_API_KEY_3=...

# Optional: NewsAPI and GNews keys (for supplementary fetch)
# NEWSAPI_KEY=...
# GNEWS_API_KEY=...

# Sentry error tracking (optional)
# SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/project-id

# Environment (development / staging / production)
# ENVIRONMENT=development

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://verifiedindian.vercel.app
